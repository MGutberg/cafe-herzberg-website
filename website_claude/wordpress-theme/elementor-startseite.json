                  {"_id": "t2","tab_title": "Mittagstisch","tab_content": "<p><strong>Suppe des Tages</strong> – 8,50 €<br>Mit Brot und Butter</p><p><strong>Quiche Lorraine</strong> – 10,90 €<br>Mit Salat der Saison</p>"},
                  {"_id": "t3","tab_title": "Kuchen & Gebäck","tab_content": "<p><strong>Berliner Cheesecake</strong> – 5,90 €</p><p><strong>Apfelkuchen</strong> – 4,80 €<br>Täglich frisch gebacken</p><p><strong>Croissant</strong> – 3,20 €<br>Butter oder Mandel</p>"},
